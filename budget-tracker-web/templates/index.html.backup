{% extends "base.html" %}

{% block title %}Dashboard - Budget Tracker{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12">
        <h1><i class="bi bi-speedometer2"></i> Dashboard Buget</h1>
        <p class="text-muted">Gestionează-ți finanțele personale în mod inteligent</p>
    </div>
</div>

<!-- Stat Cards -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-arrow-up-circle"></i> Balanță</h5>
                <h2 class="display-6">{{ "%.2f"|format(stats.balance) }} lei</h2>
                <p class="card-text">Sold curent</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cash-coin"></i> Venituri</h5>
                <h2 class="display-6">{{ "%.2f"|format(stats.total_income) }} lei</h2>
                <p class="card-text">Total încasări</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-warning text-white">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cart"></i> Cheltuieli</h5>
                <h2 class="display-6">{{ "%.2f"|format(stats.total_expenses) }} lei</h2>
                <p class="card-text">Total plăți</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-secondary text-white">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-list-check"></i> Tranzacții</h5>
                <h2 class="display-6">{{ stats.total_transactions }}</h2>
                <p class="card-text">Total operațiuni</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Formular adăugare tranzacție -->
    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Adaugă tranzacție</h5>
            </div>
            <div class="card-body">
                <form id="addTransactionForm">
                    <div class="mb-3">
                        <label class="form-label">Tip tranzacție</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="type" id="income" value="income" checked>
                            <label class="btn btn-outline-success" for="income">
                                <i class="bi bi-arrow-up-circle"></i> Venit
                            </label>
                            
                            <input type="radio" class="btn-check" name="type" id="expense" value="expense">
                            <label class="btn btn-outline-danger" for="expense">
                                <i class="bi bi-arrow-down-circle"></i> Cheltuială
                            </label>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Suma (lei)</label>
                        <div class="input-group">
                            <span class="input-group-text">RON</span>
                            <input type="number" step="0.01" min="0.01" class="form-control" 
                                   name="amount" placeholder="0.00" required>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Categorie</label>
                        <select class="form-select" name="category" id="categorySelect" required>
                            <option value="">Alege o categorie...</option>
                            <optgroup label="Venituri">
                                {% for cat in categories.income %}
                                <option value="{{ cat }}">{{ cat }}</option>
                                {% endfor %}
                            </optgroup>
                            <optgroup label="Cheltuieli">
                                {% for cat in categories.expense %}
                                <option value="{{ cat }}">{{ cat }}</option>
                                {% endfor %}
                            </optgroup>
                        </select>
                        <div class="mt-2">
                            <input type="text" class="form-control form-control-sm" 
                                   id="newCategory" placeholder="Sau creează categorie nouă...">
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-1" 
                                    id="addCategoryBtn">Adaugă categorie</button>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Descriere</label>
                        <textarea class="form-control" name="description" rows="2" 
                                  placeholder="Descriere tranzacție..." required></textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Data</label>
                        <input type="datetime-local" class="form-control" name="date" 
                               value="{{ now.strftime('%Y-%m-%dT%H:%M') if now else '' }}">
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle"></i> Adaugă tranzacție
                    </button>
                </form>
                <div id="formMessage" class="mt-3"></div>
            </div>
        </div>
        
        <!-- Grafic categorii -->
        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pie-chart"></i> Distribuție pe categorii</h5>
            </div>
            <div class="card-body">
                <canvas id="categoryChart" height="250"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Lista tranzacții și statistici -->
    <div class="col-lg-8">
        <!-- Filtre rapide -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-4">
                        <select class="form-select" id="periodFilter">
                            <option value="month">Luna curentă</option>
                            <option value="week">Ultima săptămână</option>
                            <option value="all">Toate tranzacțiile</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="date" class="form-control" id="startDate" 
                               value="{{ now.strftime('%Y-%m-01') if now else '' }}">
                    </div>
                    <div class="col-md-4">
                        <input type="date" class="form-control" id="endDate" 
                               value="{{ now.strftime('%Y-%m-%d') if now else '' }}">
                    </div>
                </div>
                <button class="btn btn-outline-primary mt-2" id="applyFilter">
                    <i class="bi bi-funnel"></i> Filtrează
                </button>
            </div>
        </div>
        
        <!-- Tranzacții recente -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Tranzacții recente</h5>
                <span class="badge bg-primary">{{ recent_transactions|length }}</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Categorie</th>
                                <th>Descriere</th>
                                <th>Tip</th>
                                <th class="text-end">Suma</th>
                                <th>Acțiuni</th>
                            </tr>
                        </thead>
                        <tbody id="transactionsTable">
                            {% for t in recent_transactions|reverse %}
                            <tr data-id="{{ t.id }}">
                                <td>{{ t.date[:16] }}</td>
                                <td>
                                    <span class="badge bg-secondary">{{ t.category }}</span>
                                </td>
                                <td>{{ t.description }}</td>
                                <td>
                                    {% if t.type.value == 'income' %}
                                    <span class="badge bg-success">Venit</span>
                                    {% else %}
                                    <span class="badge bg-danger">Cheltuială</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <span class="{{ 'text-success' if t.type.value == 'income' else 'text-danger' }}">
                                        {{ "%.2f"|format(t.amount) }} lei
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger delete-btn" 
                                            data-id="{{ t.id }}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    Nu există tranzacții încă. Adaugă prima tranzacție!
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                
                <div class="text-center mt-3">
                    <a href="/transactions" class="btn btn-outline-primary">
                        <i class="bi bi-list-ul"></i> Vezi toate tranzacțiile
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Statistici lunare -->
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-calendar-month"></i> Sumar lunar</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Selectează luna:</label>
                            <input type="month" class="form-control" id="monthSelector" 
                                   value="{{ now.strftime('%Y-%m') if now else '' }}">
                        </div>
                        <div id="monthlyStats">
                            <p><strong>Venituri:</strong> {{ "%.2f"|format(monthly_summary.income) }} lei</p>
                            <p><strong>Cheltuieli:</strong> {{ "%.2f"|format(monthly_summary.expenses) }} lei</p>
                            <p><strong>Balanță:</strong> 
                                <span class="{{ 'text-success' if monthly_summary.balance >= 0 else 'text-danger' }}">
                                    {{ "%.2f"|format(monthly_summary.balance) }} lei
                                </span>
                            </p>
                            <p><strong>Tranzacții:</strong> {{ monthly_summary.transactions }}</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-graph-up"></i> Evoluție lunară</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="monthlyChart" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize charts and event handlers
        initializeCharts();
        initializeEventHandlers();
    });
</script>
{% endblock %}