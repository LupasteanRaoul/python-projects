{% extends "base.html" %}

{% block title %}Toate Tranzacțiile - Budget Tracker{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-list-check"></i> Toate tranzacțiile</h1>
    <div>
        <a href="/export/csv" class="btn btn-success">
            <i class="bi bi-download"></i> Export CSV
        </a>
        <a href="/" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Înapoi la Dashboard
        </a>
    </div>
</div>

<!-- Filtre avansate -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-funnel"></i> Filtre avansate</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">De la data</label>
                <input type="date" class="form-control" id="filterStartDate">
            </div>
            <div class="col-md-3">
                <label class="form-label">Până la data</label>
                <input type="date" class="form-control" id="filterEndDate">
            </div>
            <div class="col-md-3">
                <label class="form-label">Categorie</label>
                <select class="form-select" id="filterCategory">
                    <option value="">Toate categoriile</option>
                    {% for cat_group in categories.values() %}
                        {% for cat in cat_group %}
                        <option value="{{ cat }}">{{ cat }}</option>
                        {% endfor %}
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tip</label>
                <select class="form-select" id="filterType">
                    <option value="">Toate tipurile</option>
                    <option value="income">Venituri</option>
                    <option value="expense">Cheltuieli</option>
                </select>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <button class="btn btn-primary" id="applyAdvancedFilter">
                    <i class="bi bi-search"></i> Aplică filtre
                </button>
                <button class="btn btn-outline-secondary" id="resetFilters">
                    <i class="bi bi-x-circle"></i> Resetează
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Lista tranzacții -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Total: {{ transactions|length }} tranzacții</h5>
        <div class="input-group" style="width: 300px;">
            <input type="text" class="form-control" placeholder="Caută tranzacții..." id="searchInput">
            <button class="btn btn-outline-secondary" type="button">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="allTransactionsTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Data & Ora</th>
                        <th>Categorie</th>
                        <th>Descriere</th>
                        <th>Tip</th>
                        <th class="text-end">Suma (lei)</th>
                        <th>Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in transactions|reverse %}
                    <tr data-id="{{ t.id }}" class="{{ 'table-success' if t.type.value == 'income' else 'table-danger' }}">
                        <td><small class="text-muted">{{ t.id[:8] }}...</small></td>
                        <td>{{ t.date }}</td>
                        <td>
                            <span class="badge bg-secondary">{{ t.category }}</span>
                        </td>
                        <td>{{ t.description }}</td>
                        <td>
                            {% if t.type.value == 'income' %}
                            <span class="badge bg-success">Venit</span>
                            {% else %}
                            <span class="badge bg-danger">Cheltuială</span>
                            {% endif %}
                        </td>
                        <td class="text-end fw-bold">
                            {{ "%.2f"|format(t.amount) }} lei
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary edit-btn" data-id="{{ t.id }}">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger delete-btn" data-id="{{ t.id }}">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                            <p class="mt-2">Nu există tranzacții încă.</p>
                            <a href="/" class="btn btn-primary mt-2">Adaugă prima tranzacție</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="table-dark">
                        <td colspan="5" class="text-end"><strong>Total:</strong></td>
                        <td class="text-end fw-bold">
                            {% set total_income = transactions|selectattr('type.value', 'equalto', 'income')|map(attribute='amount')|sum %}
                            {% set total_expense = transactions|selectattr('type.value', 'equalto', 'expense')|map(attribute='amount')|sum %}
                            {{ "%.2f"|format(total_income - total_expense) }} lei
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        
        <!-- Pagination -->
        {% if transactions|length > 20 %}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Previous</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Next</a>
                </li>
            </ul>
        </nav>
        {% endif %}
    </div>
</div>

<!-- Modal editare -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editare tranzacție</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Formular editare va fi încărcat dinamic -->
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize transactions page functionality
        initializeTransactionsPage();
    });
</script>
{% endblock %}